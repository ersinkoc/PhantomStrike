# ============================================
# PhantomStrike .gitignore
# ============================================

# --------------------------------------------
# Go
# --------------------------------------------
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Go workspace file
go.work
go.work.sum

# Build artifacts
/bin/
/dist/
/vendor/

# --------------------------------------------
# Node.js / Frontend
# --------------------------------------------
/web/node_modules/
/web/dist/
/web/dist-ssr/
/web/.cache/
/web/.parcel-cache/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
.env
.env.local
.env.*.local

# --------------------------------------------
# IDE / Editors
# --------------------------------------------
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr
*.ids
*.orig

# Vim
*.swp
*.swo
*~
.vim/

# Emacs
*~
.#*

# Sublime Text
*.sublime-workspace
*.sublime-project

# --------------------------------------------
# OS Generated Files
# --------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
*.stackdump
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.nfs*

# --------------------------------------------
# Application Specific
# --------------------------------------------
# Config files with sensitive data
config.yaml
config.yml
config.local.yaml
config.local.yml
!config.example.yaml
!config.example.yml

# Database files
*.db
*.sqlite
*.sqlite3

# Storage directories
/storage/
/data/*
!/data/.gitkeep
!/data/catalog/
/data/catalog/*
!/data/catalog/.gitkeep
/artifacts/
/uploads/
/reports/

# Tool execution outputs
/tools/_docker/
/tools/.cache/

# Knowledge base embeddings (large files)
/knowledge/*.embedding
/knowledge/.vectors/

# --------------------------------------------
# Docker
# --------------------------------------------
.dockerignore
Dockerfile.*
!Dockerfile
!Dockerfile.server
!Dockerfile.worker
!Dockerfile.mcp
docker-compose.override.yml
docker-compose.*.yml
!.env.example

# --------------------------------------------
# Testing
# --------------------------------------------
/coverage/
/.nyc_output/
*.cover
*.coverage

# --------------------------------------------
# Temporary Files
# --------------------------------------------
/tmp/
/temp/
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~

# --------------------------------------------
# Certificates and Keys
# --------------------------------------------
*.pem
*.key
*.crt
*.cer
*.der
*.p12
*.pfx

# But keep example certificates
!*.example.pem
!*.example.key

# --------------------------------------------
# Misc
# --------------------------------------------
# Git
*.orig

# Terraform (if used for deployment)
*.tfstate
*.tfstate.*
.terraform/

# Kubernetes secrets
*secret*.yaml
*secrets*.yaml
!*secret*.example.yaml
!*secrets*.example.yaml

# Archives
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# Binary files
*.bin
*.exe
*.dll
*.so
*.dylib

.projectinfo/*